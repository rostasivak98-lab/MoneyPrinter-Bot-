    last = None

    try:
        if getattr(STATE, "stream_closed", None):
            if len(STATE.stream_closed) > 0:
                last = STATE.stream_closed[-1]
    except Exception:
        last = None

    if not last:
        try:
            if getattr(STATE, "history_closed", None):
