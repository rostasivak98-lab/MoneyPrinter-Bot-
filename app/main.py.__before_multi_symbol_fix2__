def _tg_build_ha_chart_png_bytes(items):
    chart_items = []
    for x in list(items or [])[-30:]:
        if not isinstance(x, dict):
            continue
        if all(k in x for k in ("ha_open", "ha_high", "ha_low", "ha_close")):
            chart_items.append(x)

    if not chart_items:
        return None

    try:
        import io
        import matplotlib
        matplotlib.use("Agg")
        from matplotlib.figure import Figure
        from matplotlib.patches import Rectangle
    except Exception as e:
        raise RuntimeError(f"matplotlib_not_available: {e}")

    width = 1100
    height = 320
    dpi = 100
    fig = Figure(figsize=(width / dpi, height / dpi), dpi=dpi, facecolor="#0f172a")
    ax = fig.add_subplot(111)
    ax.set_facecolor("#0f172a")

    vals = []
    for x in chart_items:
        vals.extend([
            float(x["ha_high"]),
            float(x["ha_low"]),
            float(x["ha_open"]),
            float(x["ha_close"]),
        ])

    min_v = min(vals)
    max_v = max(vals)
    if max_v == min_v:
        max_v += 0.001
        min_v -= 0.001

    rng = max_v - min_v
    top_v = max_v + rng * 0.05
    bot_v = min_v - rng * 0.05

    ax.set_xlim(-0.5, len(chart_items) - 0.5)
    ax.set_ylim(bot_v, top_v)
    ax.grid(True, axis="y", color="#1f2937", linewidth=1)
    ax.grid(False, axis="x")

    for spine in ax.spines.values():
        spine.set_color("#1f2937")

    ax.tick_params(axis="x", colors="#94a3b8", labelsize=8)
    ax.tick_params(axis="y", colors="#94a3b8", labelsize=8)

    body_w = 0.55

    for i, c in enumerate(chart_items):
        ho = float(c["ha_open"])
        hh = float(c["ha_high"])
        hl = float(c["ha_low"])
        hc = float(c["ha_close"])

        is_up = hc >= ho
        color = "#10b981" if is_up else "#ef4444"

        ax.vlines(i, hl, hh, color=color, linewidth=2, zorder=2)

        body_bottom = min(ho, hc)
        body_height = max(abs(hc - ho), 1e-9)
        rect = Rectangle(
            (i - body_w / 2, body_bottom),
            body_w,
            body_height,
            facecolor=color,
            edgecolor=color,
            linewidth=1,
            zorder=3,
        )
        ax.add_patch(rect)

    ax.set_title(f"HA graf: {getattr(STATE, 'symbol', '?')}", color="#e5e7eb", fontsize=12)
    ax.set_xticks(range(len(chart_items)))
    ax.set_xticklabels([""] * len(chart_items))

    buf = io.BytesIO()
    fig.savefig(buf, format="png", facecolor=fig.get_facecolor(), bbox_inches="tight")
    return buf.getvalue()

def _tg_build_ha_chart_svg(items):
    chart_items = []
    for x in list(items or [])[-30:]:
        if not isinstance(x, dict):
            continue
        if all(k in x for k in ("ha_open", "ha_high", "ha_low", "ha_close")):
            chart_items.append(x)

    if not chart_items:
        return None

    width = 1100
    height = 320
    pad_l = 16
    pad_r = 16
    pad_t = 16
    pad_b = 24
    plot_w = width - pad_l - pad_r
    plot_h = height - pad_t - pad_b

    vals = []
    for x in chart_items:
        vals.extend([
            float(x["ha_high"]),
            float(x["ha_low"]),
            float(x["ha_open"]),
            float(x["ha_close"]),
        ])

    min_v = min(vals)
    max_v = max(vals)
    if max_v == min_v:
        max_v += 0.001
        min_v -= 0.001

    rng = max_v - min_v
    top_v = max_v + rng * 0.05
    bot_v = min_v - rng * 0.05
    full_rng = top_v - bot_v

    def y(v: float) -> float:
        n = (top_v - v) / full_rng
        return pad_t + n * plot_h

    step = plot_w / max(1, len(chart_items))
    body_w = max(4.0, step * 0.55)

    grid = []
    for i in range(5):
        gy = pad_t + (plot_h / 4) * i
        grid.append(
            f'<line x1="{pad_l}" y1="{gy:.2f}" x2="{width - pad_r}" y2="{gy:.2f}" stroke="#1f2937" stroke-width="1"/>'
        )

    candles = []
    for i, c in enumerate(chart_items):
        x_center = pad_l + step * i + step / 2

        ho = float(c["ha_open"])
        hh = float(c["ha_high"])
        hl = float(c["ha_low"])
        hc = float(c["ha_close"])

        yo = y(ho)
        yh = y(hh)
        yl = y(hl)
        yc = y(hc)

        body_top = min(yo, yc)
        body_bottom = max(yo, yc)
        body_height = max(2.0, body_bottom - body_top)

        is_up = hc >= ho
        color = "#10b981" if is_up else "#ef4444"

        candles.append(
            f'<line x1="{x_center:.2f}" y1="{yh:.2f}" x2="{x_center:.2f}" y2="{yl:.2f}" stroke="{color}" stroke-width="2"/>'
        )
        candles.append(
            f'<rect x="{(x_center - body_w / 2):.2f}" y="{body_top:.2f}" width="{body_w:.2f}" height="{body_height:.2f}" rx="1" fill="{color}" stroke="{color}" stroke-width="1"/>'
        )

    svg = (
        f'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 {width} {height}" width="{width}" height="{height}">'
        f'<rect x="0" y="0" width="{width}" height="{height}" fill="#0f172a"/>'
        + "".join(grid)
        + "".join(candles)
        + '</svg>'
    )
    return svg


