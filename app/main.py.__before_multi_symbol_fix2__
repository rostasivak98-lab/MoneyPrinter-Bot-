def _tg_answer_callback(callback_query_id: str, text_msg: str = ""):
    return _tg_call_api(
        "answerCallbackQuery",
        {
            "callback_query_id": callback_query_id,
            "text": text_msg,
        },
    )


def _tg_call_local_api(path: str, method: str = "GET"):
    url = f"http://127.0.0.1:8000{path}"
    req = urllib.request.Request(url, method=method)
    try:
        with urllib.request.urlopen(req, timeout=25) as resp:
            raw = resp.read().decode("utf-8", errors="replace")
            data = json.loads(raw)
            if isinstance(data, dict):
                return data
            return {"ok": False, "error": "invalid_json_response", "raw": raw}
    except Exception as e:
        return {"ok": False, "error": f"{type(e).__name__}: {e}", "path": path}


def _tg_safe_switch_mode(mode: str):
    mode = str(mode or "").upper().strip()
    if mode not in ("AUTO", "MANUAL"):
        return {"ok": False, "error": "invalid_mode"}
    return _tg_call_local_api(
        f"/api/switch_mode?mode={urllib.parse.quote(mode)}",
        method="POST",
    )


def _tg_safe_set_alerts(enabled_text: str):
    enabled = str(enabled_text or "").upper().strip() == "ON"
    enabled_str = "true" if enabled else "false"
    return _tg_call_local_api(
        f"/api/strategy/alerts?enabled={enabled_str}",
        method="POST",
    )


def _tg_safe_switch_symbol(symbol: str):
    symbols = list(getattr(STATE, "symbols", []) or [])
    if symbol not in symbols:
        return {"ok": False, "error": "invalid_symbol", "allowed_symbols": symbols}
    return _tg_call_local_api(
        f"/api/symbols/switch?symbol={urllib.parse.quote(symbol)}",
        method="POST",
    )



def _tg_extract_message_id(send_result):
    try:
        raw = (send_result or {}).get("response_text") or "{}"
        data = json.loads(raw)
        result = data.get("result") or {}
        mid = result.get("message_id")
        return int(mid) if mid is not None else None
    except Exception:
        return None


def _tg_delete_message(message_id: int):
    chat_id = _tg_get_chat_id()
    if not chat_id:
        return {"ok": False, "error": "missing_tg_chat_id"}
    return _tg_call_api(
        "deleteMessage",
        {
            "chat_id": str(chat_id),
            "message_id": str(message_id),
        },
    )


def _tg_schedule_delete(message_id: int, delay_sec: int = 20):
    def _runner():
        try:
            time.sleep(max(1, int(delay_sec)))
            _tg_delete_message(int(message_id))
        except Exception:
            pass

    t = threading.Thread(
        target=_runner,
        name=f"tg-delete-{message_id}",
        daemon=True,
    )
    t.start()


def _tg_send_temp_message(text_msg: str, reply_markup=None, delete_after_sec: int = 20):
    result = _tg_send_message(text_msg, reply_markup=reply_markup)
    if result and result.get("ok"):
        mid = _tg_extract_message_id(result)
        if mid is not None:
            _tg_schedule_delete(mid, delete_after_sec)
    return result


TG_ACTION_DEBOUNCE_SEC = 2.5
TG_LAST_ACTION_TS = {}


def _tg_debounce_ok(action_key: str, cooldown_sec: float = TG_ACTION_DEBOUNCE_SEC):
    now = time.time()
    last = float(TG_LAST_ACTION_TS.get(action_key, 0.0) or 0.0)
    wait_left = cooldown_sec - (now - last)
    if wait_left > 0:
        return False, round(wait_left, 1)
    TG_LAST_ACTION_TS[action_key] = now
    return True, 0.0


def _tg_handle_text_command(text_msg: str):
    cmd = str(text_msg or "").strip()

    if cmd in ("/start", "/menu"):
        _tg_send_main_menu()
        return

    if cmd == "/status":
        _tg_send_temp_message(_tg_build_status_message(), delete_after_sec=20)
        return

    if cmd == "/balance":
        _tg_send_temp_message(_tg_build_balance_message(), delete_after_sec=20)
        return

    if cmd == "/last":
        _tg_send_temp_message(_tg_build_last_signal_message(), delete_after_sec=20)
        return

    if cmd == "/chart":
        r = _tg_send_chart()
        if not r.get("ok"):
            _tg_send_message(f"❌ CHART SELHAL\n\n{r.get('error', 'unknown_error')}")
        return

    if cmd == "/auto":
        ok_go, wait_left = _tg_debounce_ok("cmd:auto")
        if not ok_go:
            _tg_send_message(f"⏳ Počkej {wait_left}s a zkus to znovu.")
            return
        d = _tg_safe_switch_mode("AUTO")
        _tg_send_message(f"⚙️ REŽIM ZMĚNĚN\n\nNový režim: {d.get('switch_mode', '?')}")
        return

    if cmd == "/manual":
        ok_go, wait_left = _tg_debounce_ok("cmd:manual")
        if not ok_go:
            _tg_send_message(f"⏳ Počkej {wait_left}s a zkus to znovu.")
            return
        d = _tg_safe_switch_mode("MANUAL")
        _tg_send_message(f"⚙️ REŽIM ZMĚNĚN\n\nNový režim: {d.get('switch_mode', '?')}")
        return

    if cmd.startswith("/symbol "):
        sym = cmd.split(" ", 1)[1].strip()
        ok_go, wait_left = _tg_debounce_ok(f"cmd:symbol:{sym}")
        if not ok_go:
            _tg_send_message(f"⏳ Počkej {wait_left}s a zkus to znovu.")
            return
        d = _tg_safe_switch_symbol(sym)
        if d.get("ok"):
            _tg_send_message(f"📊 SYMBOL ZMĚNĚN\n\nAktivní symbol: {d.get('active_symbol', sym)}")
        else:
            _tg_send_message("❌ ZMĚNA SYMBOLU SELHALA")
        return


def _tg_handle_callback(data: str, callback_query_id: str):
    if data == "menu:main":
        _tg_answer_callback(callback_query_id)
        _tg_send_main_menu()
        return

    if data == "menu:symbol":
        _tg_answer_callback(callback_query_id)
        _tg_send_message(
            f"📊 VÝBĚR SYMBOLU\n\nAktivní symbol: {getattr(STATE, 'symbol', '?')}\n\nVyber trh:",
            reply_markup=_tg_symbol_menu_markup(),
        )
        return

    if data == "menu:mode":
        _tg_answer_callback(callback_query_id)
        _tg_send_message(
            f"⚙️ REŽIM BOTA\n\nAktuálně: {getattr(STATE, 'switch_mode', '?')}\n\nVyber nový režim:",
            reply_markup=_tg_mode_menu_markup(),
        )
        return

    if data == "menu:alerts":
        _tg_answer_callback(callback_query_id)
        _tg_send_message(
            f"🔔 UPOZORNĚNÍ\n\nAktuálně: {'ON' if bool(globals().get('STRATEGY_V1_ALERTS_ENABLED', False)) else 'OFF'}\n\nVyber nastavení:",
            reply_markup=_tg_alerts_menu_markup(),
        )
        return

    if data == "show:status":
        _tg_answer_callback(callback_query_id)
        _tg_send_temp_message(_tg_build_status_message(), delete_after_sec=20)
        return

    if data == "show:balance":
        _tg_answer_callback(callback_query_id)
        _tg_send_temp_message(_tg_build_balance_message(), delete_after_sec=20)
        return

    if data == "show:last":
        _tg_answer_callback(callback_query_id)
        _tg_send_temp_message(_tg_build_last_signal_message(), delete_after_sec=20)
        return

    if data == "show:chart":
        _tg_answer_callback(callback_query_id, "Posílám chart...")
        r = _tg_send_chart()
        if not r.get("ok"):
            _tg_send_message(f"❌ CHART SELHAL\n\n{r.get('error', 'unknown_error')}")
        return

    if data.startswith("set_mode:"):
        mode = data.split(":", 1)[1]
        ok_go, wait_left = _tg_debounce_ok(f"cb:set_mode:{mode}")
        if not ok_go:
            _tg_answer_callback(callback_query_id, f"Počkej {wait_left}s")
            return
        _tg_answer_callback(callback_query_id, "Přepínám režim...")
        d = _tg_safe_switch_mode(mode)
        if d.get("ok"):
            _tg_send_message(f"⚙️ REŽIM ZMĚNĚN\n\nNový režim: {d.get('switch_mode', '?')}")
        else:
            _tg_send_message(f"❌ ZMĚNA REŽIMU SELHALA\n\n{d.get('error', 'unknown_error')}")
        return

    if data.startswith("set_alerts:"):
        val = data.split(":", 1)[1]
        ok_go, wait_left = _tg_debounce_ok(f"cb:set_alerts:{val}")
        if not ok_go:
            _tg_answer_callback(callback_query_id, f"Počkej {wait_left}s")
            return
        _tg_answer_callback(callback_query_id, "Přepínám alerts...")
        d = _tg_safe_set_alerts(val)
        if d.get("ok"):
            state = "ZAPNUTÉ" if d.get("alerts_enabled") else "VYPNUTÉ"
            _tg_send_message(f"🔔 UPOZORNĚNÍ\n\nTelegram oznámení jsou {state}")
        else:
            _tg_send_message(f"❌ ZMĚNA ALERTS SELHALA\n\n{d.get('error', 'unknown_error')}")
        return

    if data.startswith("set_symbol:"):
        sym = data.split(":", 1)[1]
        ok_go, wait_left = _tg_debounce_ok(f"cb:set_symbol:{sym}")
        if not ok_go:
            _tg_answer_callback(callback_query_id, f"Počkej {wait_left}s")
            return
        _tg_answer_callback(callback_query_id, "Přepínám symbol...")
        d = _tg_safe_switch_symbol(sym)
        if d.get("ok"):
            _tg_send_message(f"📊 SYMBOL ZMĚNĚN\n\nAktivní symbol: {d.get('active_symbol', sym)}")
        else:
            _tg_send_message(f"❌ ZMĚNA SYMBOLU SELHALA\n\n{d.get('error', 'unknown_error')}")
        return


def _tg_poll_once():
    global TG_LAST_UPDATE_ID

    chat_id = _tg_get_chat_id()
    if not chat_id:
        return

    result = _tg_call_api(
        "getUpdates",
        {
            "offset": int(TG_LAST_UPDATE_ID or 0) + 1,
            "timeout": 20,
            "allowed_updates": ["message", "callback_query"],
        },
    )
    if not result.get("ok"):
        return

    raw = result.get("response_text") or "{}"
    data = __import__("json").loads(raw)

    for upd in data.get("result", []):
        TG_LAST_UPDATE_ID = max(int(TG_LAST_UPDATE_ID or 0), int(upd.get("update_id") or 0))

        if upd.get("message"):
            msg = upd["message"]
            incoming_chat_id = str(((msg.get("chat") or {}).get("id") or ""))
            if incoming_chat_id != str(chat_id):
                continue
            text_msg = str(msg.get("text") or "").strip()
            if text_msg.startswith("/"):
                _tg_handle_text_command(text_msg)

        if upd.get("callback_query"):
            cq = upd["callback_query"]
            incoming_chat_id = str((((cq.get("message") or {}).get("chat") or {}).get("id") or ""))
            if incoming_chat_id != str(chat_id):
                continue
            _tg_handle_callback(
                data=str(cq.get("data") or ""),
                callback_query_id=str(cq.get("id") or ""),
            )


def _tg_menu_loop():
    global TG_MENU_RUNNING
    if TG_MENU_RUNNING:
        return
    TG_MENU_RUNNING = True

    def _runner():
        while True:
            try:
                if _tg_is_ready():
                    _tg_poll_once()
            except Exception:
                pass
            time.sleep(1)

    t = threading.Thread(target=_runner, name="telegram-menu-loop", daemon=True)
    t.start()


@app.on_event("startup")
def _tg_menu_startup():
    _tg_menu_loop()
