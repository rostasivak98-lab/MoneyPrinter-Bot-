def _get_symbol_switch_async_lock():
    global SYMBOL_SWITCH_ASYNC_LOCK
    if SYMBOL_SWITCH_ASYNC_LOCK is None:
        SYMBOL_SWITCH_ASYNC_LOCK = asyncio.Lock()
    return SYMBOL_SWITCH_ASYNC_LOCK


def _get_engine_start_async_lock():
    global ENGINE_START_ASYNC_LOCK
    if ENGINE_START_ASYNC_LOCK is None:
        ENGINE_START_ASYNC_LOCK = asyncio.Lock()
