    lock = _get_engine_start_async_lock()
    async with lock:
        if _engine_task and not _engine_task.done():
            STATE.running = True
            return {"ok": True, "msg": "already running"}
        _stop_event.clear()
        STATE.running = True
        _engine_task = asyncio.create_task(_engine_loop())
