STRATEGY_V1_LOOKBACK = 7
STRATEGY_V1_TREND_WINDOW = 5
STRATEGY_V1_EPS = 1e-9


def _strategy_v1__dedup_by_timestamp(items):
    out = []
    seen = set()
    for item in reversed(items):
        ts = None
        if isinstance(item, dict):
            ts = item.get("timestamp")
        if ts in seen:
            continue
        seen.add(ts)
        out.append(item)
    out.reverse()
    return out


def _strategy_v1__to_dict(x):
    if isinstance(x, dict):
        return dict(x)
    if hasattr(x, "model_dump"):
        try:
            return dict(x.model_dump())
        except Exception:
            pass
    if hasattr(x, "dict"):
        try:
            return dict(x.dict())
        except Exception:
            pass
    data = {}
    for key in (
        "symbol", "timestamp", "open", "high", "low", "close", "volume",
        "source", "open_time", "close_time", "age_sec"
    ):
        if hasattr(x, key):
            try:
                data[key] = getattr(x, key)
            except Exception:
                pass
    return data


def _strategy_v1__get_closed_raw():
    history_items = list(getattr(STATE, "history_closed", []) or [])
    stream_items = list(getattr(STATE, "stream_closed", []) or [])
    merged = [_strategy_v1__to_dict(x) for x in history_items + stream_items]
    merged = [x for x in merged if isinstance(x, dict) and x.get("timestamp") is not None]
    merged = _strategy_v1__dedup_by_timestamp(merged)
    merged.sort(key=lambda x: x.get("timestamp", 0))
    return merged


def _strategy_v1__compute_ha(raw_items):
    out = []
    prev_ha_open = None
    prev_ha_close = None

    for raw in raw_items:
        c = _strategy_v1__to_dict(raw)

        if not all(k in c for k in ("open", "high", "low", "close")):
            out.append(c)
            continue

        o = float(c["open"])
        h = float(c["high"])
        l = float(c["low"])
        cl = float(c["close"])

        ha_close = (o + h + l + cl) / 4.0

        if prev_ha_open is None or prev_ha_close is None:
            ha_open = (o + cl) / 2.0
        else:
            ha_open = (prev_ha_open + prev_ha_close) / 2.0

        ha_high = max(h, ha_open, ha_close)
        ha_low = min(l, ha_open, ha_close)
        ha_dir = "UP" if ha_close >= ha_open else "DOWN"

        c["ha_open"] = ha_open
        c["ha_high"] = ha_high
        c["ha_low"] = ha_low
        c["ha_close"] = ha_close
        c["ha_dir"] = ha_dir

        prev_ha_open = ha_open
        prev_ha_close = ha_close
        out.append(c)

    return out


def _strategy_v1__get_closed_ha():
    return _strategy_v1__compute_ha(_strategy_v1__get_closed_raw())


def _strategy_v1__get_forming_ha():
    current = getattr(STATE, "stream_current", None)
    if not current:
        return None

    closed_ha = _strategy_v1__get_closed_ha()
    raw_items = [_strategy_v1__to_dict(x) for x in _strategy_v1__get_closed_raw()]
    raw_items.append(_strategy_v1__to_dict(current))
    full = _strategy_v1__compute_ha(raw_items)
    if not full:
        return None

    forming = full[-1]
    last_closed_ts = closed_ha[-1]["timestamp"] if closed_ha else None
    forming["is_new_after_closed"] = (
        last_closed_ts is not None and forming.get("timestamp") != last_closed_ts
    )
    return forming


def _strategy_v1__body_size(c):
    return abs(float(c["ha_close"]) - float(c["ha_open"]))


def _strategy_v1__upper_wick(c):
    return float(c["ha_high"]) - max(float(c["ha_open"]), float(c["ha_close"]))


def _strategy_v1__lower_wick(c):
    return min(float(c["ha_open"]), float(c["ha_close"])) - float(c["ha_low"])


def _strategy_v1__is_cross(c, eps=STRATEGY_V1_EPS):
    try:
        return _strategy_v1__upper_wick(c) > eps and _strategy_v1__lower_wick(c) > eps
    except Exception:
        return False


def _strategy_v1__alternations(items):
    if len(items) < 2:
        return 0
    n = 0
    prev = items[0].get("ha_dir")
    for item in items[1:]:
        cur = item.get("ha_dir")
        if cur != prev:
            n += 1
        prev = cur
    return n


def _strategy_v1__trend_state(closed_ha):
    window = closed_ha[-STRATEGY_V1_TREND_WINDOW:] if len(closed_ha) >= 1 else []

    if len(window) < 3:
        return {
            "trend_buy": False,
            "trend_sell": False,
            "chaos": True,
            "up_count": 0,
            "down_count": 0,
            "alternations": 0,
            "net_ha_move": 0.0,
            "last2_up": 0,
            "last2_down": 0,
            "last3_up": 0,
            "last3_down": 0,
            "cross_count": 0,
            "clean_body_count": 0,
            "env_ok": False,
            "reason": "not_enough_closed_candles"
        }

    up_count = sum(1 for x in window if x.get("ha_dir") == "UP")
    down_count = sum(1 for x in window if x.get("ha_dir") == "DOWN")
    alternations = _strategy_v1__alternations(window)
    net_ha_move = float(window[-1]["ha_close"]) - float(window[0]["ha_close"])

    last2 = window[-2:]
    last3 = window[-3:]

    last2_up = sum(1 for x in last2 if x.get("ha_dir") == "UP")
    last2_down = sum(1 for x in last2 if x.get("ha_dir") == "DOWN")
    last3_up = sum(1 for x in last3 if x.get("ha_dir") == "UP")
    last3_down = sum(1 for x in last3 if x.get("ha_dir") == "DOWN")

    cross_count = sum(1 for x in window if _strategy_v1__is_cross(x))

    clean_body_count = 0
    for x in window:
        body = _strategy_v1__body_size(x)
        upper = _strategy_v1__upper_wick(x)
        lower = _strategy_v1__lower_wick(x)
        if body > (upper + lower):
            clean_body_count += 1

    env_ok = (
        alternations <= 2 and
        cross_count <= 3 and
        clean_body_count >= 1
    )

    trend_buy_base = (
        up_count >= 4 and
        net_ha_move > 0 and
        env_ok
    )

    trend_sell_base = (
        down_count >= 4 and
        net_ha_move < 0 and
        env_ok
    )

    recent_buy_push = (
        (last2_up == 2) or
        (last3_up >= 2 and float(last3[-1]["ha_close"]) >= float(last3[0]["ha_close"]))
    )

    recent_sell_push = (
        (last2_down == 2) or
        (last3_down >= 2 and float(last3[-1]["ha_close"]) <= float(last3[0]["ha_close"]))
    )

    trend_buy = trend_buy_base and not recent_sell_push
    trend_sell = trend_sell_base and not recent_buy_push

    if recent_buy_push and not recent_sell_push:
        trend_sell = False

    if recent_sell_push and not recent_buy_push:
        trend_buy = False

    chaos = (
        alternations >= 4 or
        cross_count >= 4 or
        (not env_ok and alternations >= 3) or
        (not trend_buy and not trend_sell)
    )

    reason = []
    if trend_buy:
        reason.append("trend_buy_ok")
    if trend_sell:
        reason.append("trend_sell_ok")
    if recent_buy_push:
        reason.append("recent_buy_push")
    if recent_sell_push:
        reason.append("recent_sell_push")
    if not env_ok:
        reason.append("environment_not_clean")
    if chaos:
        reason.append("chaos_or_no_trade")

    return {
        "trend_buy": trend_buy,
        "trend_sell": trend_sell,
        "chaos": chaos,
        "up_count": up_count,
        "down_count": down_count,
        "alternations": alternations,
        "net_ha_move": net_ha_move,
        "last2_up": last2_up,
        "last2_down": last2_down,
        "last3_up": last3_up,
        "last3_down": last3_down,
        "cross_count": cross_count,
        "clean_body_count": clean_body_count,
        "env_ok": env_ok,
        "reason": ",".join(reason) if reason else "neutral"
    }


def _strategy_v1__reaction_buy_ok(forming):
    if not forming:
        return False
    try:
        return (
            forming.get("ha_dir") == "UP" and
            _strategy_v1__lower_wick(forming) <= STRATEGY_V1_EPS and
            _strategy_v1__body_size(forming) > STRATEGY_V1_EPS
        )
    except Exception:
        return False


def _strategy_v1__reaction_sell_ok(forming):
    if not forming:
        return False
    try:
        return (
            forming.get("ha_dir") == "DOWN" and
            _strategy_v1__upper_wick(forming) <= STRATEGY_V1_EPS and
            _strategy_v1__body_size(forming) > STRATEGY_V1_EPS
        )
    except Exception:
        return False


def _strategy_v1__build_debug():
    closed_ha = _strategy_v1__get_closed_ha()
    forming = _strategy_v1__get_forming_ha()

    trend = _strategy_v1__trend_state(closed_ha)

    prev_candle = closed_ha[-2] if len(closed_ha) >= 2 else None
    last_candle = closed_ha[-1] if len(closed_ha) >= 1 else None

    prev_candle_is_cross = _strategy_v1__is_cross(prev_candle) if prev_candle else False
    last_candle_is_cross = _strategy_v1__is_cross(last_candle) if last_candle else False
    two_crosses = prev_candle_is_cross and last_candle_is_cross

    def _window_bias_info(window_size: int):
        items = list(closed_ha[-window_size:] if closed_ha else [])
        if not items:
            return {
                "window": window_size,
                "bias": "CHAOS",
                "reason": "no_data",
                "up_count": 0,
                "down_count": 0,
                "cross_count": 0,
                "alternations": 0,
                "net_ha_move": 0.0,
                "longest_up_block": 0,
                "longest_down_block": 0,
                "right_run_dir": "NONE",
                "right_run_len": 0,
                "clean_body_count": 0,
                "chop_penalty": 0,
            }

        dirs = []
        for x in items:
            d = x.get("ha_dir")
            if d not in ("UP", "DOWN"):
                try:
                    d = "UP" if float(x.get("ha_close", 0)) >= float(x.get("ha_open", 0)) else "DOWN"
                except Exception:
                    d = "DOWN"
            dirs.append(d)

        up_count = sum(1 for d in dirs if d == "UP")
        down_count = sum(1 for d in dirs if d == "DOWN")
        cross_count = sum(1 for x in items if _strategy_v1__is_cross(x))
        alternations = _strategy_v1__alternations(items)
        clean_body_count = sum(1 for x in items if not _strategy_v1__is_cross(x))

        try:
            net_ha_move = float(items[-1].get("ha_close", 0)) - float(items[0].get("ha_open", 0))
        except Exception:
            net_ha_move = 0.0

        longest_up_block = 0
        longest_down_block = 0
        cur_dir = None
        cur_len = 0
        for d in dirs:
            if d == cur_dir:
                cur_len += 1
            else:
                cur_dir = d
                cur_len = 1
            if d == "UP":
                longest_up_block = max(longest_up_block, cur_len)
            else:
                longest_down_block = max(longest_down_block, cur_len)

        right_run_dir = dirs[-1] if dirs else "NONE"
        right_run_len = 0
        for d in reversed(dirs):
            if d == right_run_dir:
                right_run_len += 1
            else:
                break

        cross_cap = max(2, len(items) // 4)
        clean_cap = max(2, len(items) // 2)

        dominant_up_clean = bool(
            up_count >= max(down_count + 3, int(len(items) * 0.65)) and
            right_run_dir == "UP" and
            right_run_len >= 3 and
            alternations <= 2 and
            cross_count <= cross_cap and
            clean_body_count >= clean_cap and
            longest_up_block >= 3
        )

        dominant_down_clean = bool(
            down_count >= max(up_count + 3, int(len(items) * 0.65)) and
            right_run_dir == "DOWN" and
            right_run_len >= 3 and
            alternations <= 2 and
            cross_count <= cross_cap and
            clean_body_count >= clean_cap and
            longest_down_block >= 3
        )

        bias = "CHAOS"
        reason = "mixed_or_choppy"
        if dominant_up_clean:
            bias = "BUY"
            reason = "dominant_up_clean"
        elif dominant_down_clean:
            bias = "SELL"
            reason = "dominant_down_clean"

        chop_penalty = cross_count + alternations + max(0, clean_cap - clean_body_count)

        return {
            "window": window_size,
            "bias": bias,
            "reason": reason,
            "up_count": up_count,
            "down_count": down_count,
            "cross_count": cross_count,
            "alternations": alternations,
            "net_ha_move": net_ha_move,
            "longest_up_block": longest_up_block,
            "longest_down_block": longest_down_block,
            "right_run_dir": right_run_dir,
            "right_run_len": right_run_len,
            "clean_body_count": clean_body_count,
            "chop_penalty": chop_penalty,
        }

    market_bias_windows = [_window_bias_info(w) for w in (8, 12, 16)]
    buy_votes = sum(1 for w in market_bias_windows if w.get("bias") == "BUY")
    sell_votes = sum(1 for w in market_bias_windows if w.get("bias") == "SELL")
    chaos_votes = sum(1 for w in market_bias_windows if w.get("bias") == "CHAOS")

    market_bias_gate = "CHAOS"
    if buy_votes >= 2 and sell_votes == 0:
        market_bias_gate = "BUY"
    elif sell_votes >= 2 and buy_votes == 0:
        market_bias_gate = "SELL"

    market_bias_reason = f"chaos_votes={chaos_votes},buy_votes={buy_votes},sell_votes={sell_votes}"
    market_bias_blocks_entry = (market_bias_gate == "CHAOS")

    local_state = "NONE"
    local_state_reason = "no_local_pattern"

    right_edge_cross_ok = bool(
        (last_candle_is_cross and not prev_candle_is_cross) or
        (not last_candle_is_cross)
    )

    local_edge_clean_ok = bool(
        trend["env_ok"] and
        trend["alternations"] <= 1 and
        trend["cross_count"] <= 2 and
        right_edge_cross_ok
    )

    local_buy_dominance_ok = bool(
        trend["last2_up"] == 2 and
        trend["up_count"] >= trend["down_count"] and
        trend["net_ha_move"] > 0 and
        trend["down_count"] <= 1
    )

    local_sell_dominance_ok = bool(
        trend["last2_down"] == 2 and
        trend["down_count"] >= trend["up_count"] and
        trend["net_ha_move"] < 0 and
        trend["up_count"] <= 1
    )

    if market_bias_gate == "BUY" and trend["last2_up"] == 2:
        local_state = "WAIT_BUY"
        local_state_reason = "bias_buy_and_last2_up"
    elif market_bias_gate == "SELL" and trend["last2_down"] == 2:
        local_state = "WAIT_SELL"
        local_state_reason = "bias_sell_and_last2_down"
    elif market_bias_gate != "BUY" and local_edge_clean_ok and local_buy_dominance_ok:
        local_state = "EARLY_BUY"
        local_state_reason = "right_edge_turning_up_before_bias_buy"
    elif market_bias_gate != "SELL" and local_edge_clean_ok and local_sell_dominance_ok:
        local_state = "EARLY_SELL"
        local_state_reason = "right_edge_turning_down_before_bias_sell"

    market_state_v2 = "CHAOS"
    market_state_v2_reason = "bias_local_not_aligned"

    short_window = None
    for w in market_bias_windows:
        if int(w.get("window", 0) or 0) == 8:
            short_window = w
            break

    short_bias = short_window.get("bias") if short_window else None
    short_reason = short_window.get("reason") if short_window else None

    strong_short_buy_override = bool(
        market_bias_gate == "CHAOS" and
        short_bias == "BUY" and
        short_reason == "dominant_up_clean" and
        trend["env_ok"] and
        trend["last2_up"] == 2 and
        trend["last3_up"] >= 2 and
        local_state in ("EARLY_BUY", "WAIT_BUY")
    )

    strong_short_sell_override = bool(
        market_bias_gate == "CHAOS" and
        short_bias == "SELL" and
        short_reason == "dominant_down_clean" and
        trend["env_ok"] and
        trend["last2_down"] == 2 and
        trend["last3_down"] >= 2 and
        local_state in ("EARLY_SELL", "WAIT_SELL")
    )

    if market_bias_gate == "BUY" and local_state == "WAIT_BUY":
        market_state_v2 = "CLEAN_BUY"
        market_state_v2_reason = "bias_buy_plus_wait_buy"
    elif market_bias_gate == "SELL" and local_state == "WAIT_SELL":
        market_state_v2 = "CLEAN_SELL"
        market_state_v2_reason = "bias_sell_plus_wait_sell"
    elif strong_short_buy_override and local_state == "WAIT_BUY":
        market_state_v2 = "CLEAN_BUY"
        market_state_v2_reason = "short_window_8_buy_override"
    elif strong_short_sell_override and local_state == "WAIT_SELL":
        market_state_v2 = "CLEAN_SELL"
        market_state_v2_reason = "short_window_8_sell_override"
    elif strong_short_buy_override and local_state == "EARLY_BUY":
        market_state_v2 = "EARLY_BUY"
        market_state_v2_reason = "short_window_8_early_buy_override"
    elif strong_short_sell_override and local_state == "EARLY_SELL":
        market_state_v2 = "EARLY_SELL"
        market_state_v2_reason = "short_window_8_early_sell_override"
    elif market_bias_gate == "CHAOS" and local_state == "EARLY_BUY":
        market_state_v2 = "EARLY_BUY"
        market_state_v2_reason = "chaos_bias_but_right_edge_early_buy"
    elif market_bias_gate == "CHAOS" and local_state == "EARLY_SELL":
        market_state_v2 = "EARLY_SELL"
        market_state_v2_reason = "chaos_bias_but_right_edge_early_sell"

    market_state_main = market_state_v2
    market_state_main_reason = market_state_v2_reason
    market_state_buy = market_state_main in ("EARLY_BUY", "CLEAN_BUY")
    market_state_sell = market_state_main in ("EARLY_SELL", "CLEAN_SELL")

    raw_prepare_buy = bool(
        market_state_buy and
        two_crosses and
        not market_bias_blocks_entry
    )
    raw_prepare_sell = bool(
        market_state_sell and
        two_crosses and
        not market_bias_blocks_entry
    )

    symbol = getattr(STATE, "symbol", None) or "?"
    tracker = STRATEGY_V1_SETUP_TRACKERS.get(symbol)
    tracker_just_created = False
    last_closed_ts = last_candle.get("timestamp") if last_candle else None

    if tracker and tracker.get("last_closed_ts") != last_closed_ts and last_closed_ts is not None:
        tracker["candles_waited"] = int(tracker.get("candles_waited", 0) or 0) + 1
        tracker["last_closed_ts"] = last_closed_ts

    if raw_prepare_buy and not tracker:
        tracker = {
            "side": "BUY",
            "candles_waited": 0,
            "start_closed_ts": last_closed_ts,
            "last_closed_ts": last_closed_ts,
        }
        STRATEGY_V1_SETUP_TRACKERS[symbol] = tracker
        tracker_just_created = True
    elif raw_prepare_sell and not tracker:
        tracker = {
            "side": "SELL",
            "candles_waited": 0,
            "start_closed_ts": last_closed_ts,
            "last_closed_ts": last_closed_ts,
        }
        STRATEGY_V1_SETUP_TRACKERS[symbol] = tracker
        tracker_just_created = True

    tracker = STRATEGY_V1_SETUP_TRACKERS.get(symbol)

    setup_timeout = False
    setup_chaos_reset = False
    if tracker:
        if market_state_main == "CHAOS" or market_bias_blocks_entry:
            setup_chaos_reset = True
            STRATEGY_V1_SETUP_TRACKERS.pop(symbol, None)
            tracker = None
        elif int(tracker.get("candles_waited", 0) or 0) >= 3:
            setup_timeout = True
            STRATEGY_V1_SETUP_TRACKERS.pop(symbol, None)
            tracker = None

    prepare_buy = bool(tracker and tracker.get("side") == "BUY" and market_state_buy and not setup_timeout and not setup_chaos_reset)
    prepare_sell = bool(tracker and tracker.get("side") == "SELL" and market_state_sell and not setup_timeout and not setup_chaos_reset)

    new_candle_started = bool(forming and forming.get("is_new_after_closed"))
    new_candle_direction_buy_ok = bool(forming and float(forming.get("close", 0)) > float(forming.get("open", 0)))
    new_candle_direction_sell_ok = bool(forming and float(forming.get("close", 0)) < float(forming.get("open", 0)))

    reaction_buy_ok = bool(_strategy_v1__reaction_buy_ok(forming))
    reaction_sell_ok = bool(_strategy_v1__reaction_sell_ok(forming))

    final_buy = bool(prepare_buy and reaction_buy_ok and not tracker_just_created)
    final_sell = bool(prepare_sell and reaction_sell_ok and not tracker_just_created)

    if final_buy or final_sell:
        STRATEGY_V1_SETUP_TRACKERS.pop(symbol, None)

    reason = []
    if market_state_main == "CHAOS":
        reason.append("main_chaos")
    if market_bias_blocks_entry:
        reason.append("market_bias_chaos_block")
    if two_crosses:
        reason.append("two_crosses")
    if prepare_buy:
        reason.append("prepare_buy")
    if prepare_sell:
        reason.append("prepare_sell")
    if final_buy:
        reason.append("final_buy")
    if final_sell:
        reason.append("final_sell")
    if setup_timeout:
        reason.append("setup_timeout_3_candles")
    if setup_chaos_reset:
        reason.append("setup_reset_chaos")
    if not reason:
        reason.append("no_signal")

    if final_buy:
        state = "FINAL_BUY"
    elif final_sell:
        state = "FINAL_SELL"
    elif prepare_buy:
        state = "PREPARE_BUY"
    elif prepare_sell:
        state = "PREPARE_SELL"
    elif market_state_main == "CHAOS":
        state = "CHAOS_NO_TRADE"
    elif market_state_main == "CLEAN_BUY":
        state = "CLEAN_BUY"
    elif market_state_main == "CLEAN_SELL":
        state = "CLEAN_SELL"
    elif market_state_main == "EARLY_BUY":
        state = "EARLY_BUY"
    elif market_state_main == "EARLY_SELL":
        state = "EARLY_SELL"
    else:
        state = "NO_SIGNAL"

    snapshot = []
    for x in closed_ha[-STRATEGY_V1_LOOKBACK:]:
        row = {
            "timestamp": x.get("timestamp"),
            "open_time": x.get("open_time"),
            "ha_open": x.get("ha_open"),
            "ha_high": x.get("ha_high"),
            "ha_low": x.get("ha_low"),
            "ha_close": x.get("ha_close"),
            "ha_dir": x.get("ha_dir"),
            "is_cross": _strategy_v1__is_cross(x),
        }
        snapshot.append(row)

    forming_out = None
    if forming:
        forming_out = {
            "timestamp": forming.get("timestamp"),
            "open_time": forming.get("open_time"),
            "close_time": forming.get("close_time"),
            "open": forming.get("open"),
            "high": forming.get("high"),
            "low": forming.get("low"),
            "close": forming.get("close"),
            "ha_open": forming.get("ha_open"),
            "ha_high": forming.get("ha_high"),
            "ha_low": forming.get("ha_low"),
            "ha_close": forming.get("ha_close"),
            "ha_dir": forming.get("ha_dir"),
            "is_new_after_closed": forming.get("is_new_after_closed"),
            "lower_wick": _strategy_v1__lower_wick(forming),
            "upper_wick": _strategy_v1__upper_wick(forming),
            "body_size": _strategy_v1__body_size(forming),
        }

    return {
